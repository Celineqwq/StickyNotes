<Window x:Class="StickyNotes.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:StickyNotes.Controls"
        xmlns:models="clr-namespace:StickyNotes.Models"
        Title="便利贴"
        WindowStyle="None"
        Background="#F5F5F5"
        ResizeMode="CanResizeWithGrip"
        Topmost="{Binding Settings.AlwaysOnTop}"
        MinWidth="280" MinHeight="200"
        WindowStartupLocation="Manual"
        SizeChanged="Window_SizeChanged">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0"
                      GlassFrameThickness="0"
                      CornerRadius="12"
                      ResizeBorderThickness="4" />
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Templates/StickyNoteStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- ─── Thin ScrollBar (default template, only style Thumb) ─── -->
            <Style x:Key="ThinScrollBar" TargetType="ScrollBar">
                <Setter Property="Width" Value="4" />
                <Setter Property="MinWidth" Value="0" />
                <Setter Property="Background" Value="Transparent" />
            </Style>

            <Style x:Key="ThinScrollThumb" TargetType="Thumb">
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="MinWidth" Value="2" />
                <Setter Property="MinHeight" Value="16" />
                <Setter Property="Width" Value="2" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Thumb">
                            <Border x:Name="ThumbBorder"
                                    Background="#44AAAAAA"
                                    CornerRadius="3" />
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="ThumbBorder" Property="Background" Value="#AA888888" />
                                </Trigger>
                                <Trigger Property="IsDragging" Value="True">
                                    <Setter TargetName="ThumbBorder" Property="Background" Value="#CC666666" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Border x:Name="MainBorder"
            Background="#F5F5F5"
            CornerRadius="12"
            BorderBrush="#E0E0E0"
            BorderThickness="1">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="30" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- ═══ Title Bar ═══ -->
            <Border Grid.Row="0"
                    Background="#F0F0F0"
                    CornerRadius="12,12,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="30" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="30" />
                    </Grid.ColumnDefinitions>

                    <!-- Pin (always on top) toggle -->
                    <ToggleButton x:Name="PinButton"
                                  Grid.Column="0"
                                  Width="30" Height="30"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  Cursor="Hand"
                                  IsChecked="{Binding Settings.AlwaysOnTop}"
                                  ToolTip="置顶锁定"
                                  Checked="PinButton_Checked"
                                  Unchecked="PinButton_Unchecked">
                        <TextBlock x:Name="PinIcon"
                                   Text="○"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Foreground="#AAA"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </ToggleButton>

                    <TextBlock Grid.Column="1"
                           Text="便利贴"
                           FontSize="13"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Foreground="#555"
                           MouseLeftButtonDown="TitleText_MouseLeftButtonDown" />

                    <!-- Mini mode -->
                    <Button Grid.Column="2"
                            Content="●"
                            FontSize="14"
                            Width="28" Height="28"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            Foreground="#888"
                            ToolTip="切换到悬浮球"
                            Click="MiniModeButton_Click" />

                    <!-- Settings -->
                    <Button Grid.Column="3"
                            Content="⚙"
                            FontSize="16"
                            Width="28" Height="28"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            Foreground="#888"
                            ToolTip="设置"
                            Click="SettingsButton_Click" />

                    <!-- Add note -->
                    <Button Grid.Column="4"
                            x:Name="TitleAddButton"
                            Content="＋"
                            FontSize="18"
                            Width="28" Height="28"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            Foreground="#888"
                            ToolTip="添加便利贴"
                            Click="TitleAddButton_Click" />

                    <!-- Minimize -->
                    <Button Grid.Column="5"
                            Content="─"
                            FontSize="16"
                            Width="28" Height="28"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            Foreground="#888"
                            ToolTip="最小化到托盘"
                            Click="MinimizeButton_Click" />

                    <!-- Close -->
                    <Button Grid.Column="6"
                            Content="×"
                            FontSize="16"
                            Foreground="#888"
                            Width="30" Height="30"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            ToolTip="退出"
                            Click="CloseButton_Click">
                        <Button.Triggers>
                            <EventTrigger RoutedEvent="Button.MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetProperty="Foreground.Color"
                                                        To="#FF4444" Duration="0:0:0.15" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="Button.MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetProperty="Foreground.Color"
                                                        To="#888888" Duration="0:0:0.15" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Button.Triggers>
                    </Button>
                </Grid>
            </Border>

            <!-- ═══ Notes List ═══ -->
            <Grid Grid.Row="1" Margin="6,4,6,6">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Batch action bar -->
                <Border x:Name="BatchBar"
                        Grid.Row="1"
                        Background="#E8F5E9"
                        CornerRadius="6"
                        Padding="8,4"
                        Margin="0,4,0,4"
                        Visibility="Collapsed">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="6" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="6" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="BatchCountText"
                                   Grid.Column="0"
                                   Text="已选择 0 项"
                                   FontSize="12"
                                   VerticalAlignment="Center"
                                   Foreground="#2E7D32" />
                        <Button Grid.Column="2"
                                Content="取消选择"
                                FontSize="12"
                                Height="26"
                                Padding="8,0"
                                Background="Transparent"
                                BorderThickness="1"
                                BorderBrush="#CCC"
                                Cursor="Hand"
                                Foreground="#666"
                                Click="DeselectAll_Click" />
                        <Button x:Name="DeleteSelectedButton"
                                Grid.Column="4"
                                Content="🗑 删除选中"
                                FontSize="12"
                                Height="26"
                                Padding="8,0"
                                Background="#FFEBEE"
                                BorderThickness="1"
                                BorderBrush="#EF9A9A"
                                Cursor="Hand"
                                Foreground="#C62828"
                                Click="DeleteSelected_Click" />
                        <Button x:Name="ExportSelectedButton"
                                Grid.Column="6"
                                Content="📦 导出选中"
                                FontSize="12"
                                Height="26"
                                Padding="8,0"
                                Background="#E3F2FD"
                                BorderThickness="1"
                                BorderBrush="#90CAF9"
                                Cursor="Hand"
                                Foreground="#1565C0"
                                Click="ExportSelected_Click" />
                    </Grid>
                </Border>

                <ListBox x:Name="NotesListBox"
                         Grid.Row="0"
                         ItemsSource="{Binding Notes}"
                         Background="Transparent"
                         BorderThickness="0"
                         Focusable="False"
                         VirtualizingPanel.IsVirtualizing="False"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         AllowDrop="True"
                         PreviewDragOver="NotesList_DragOver"
                         Drop="NotesList_Drop"
                         PreviewKeyDown="NotesListBox_PreviewKeyDown">

                    <ListBox.Resources>
                        <Style TargetType="ScrollBar" BasedOn="{StaticResource ThinScrollBar}" />
                        <Style TargetType="Thumb" BasedOn="{StaticResource ThinScrollThumb}" />
                    </ListBox.Resources>

                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="IsHitTestVisible" Value="True" />
                            <Setter Property="Focusable" Value="False" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <ContentPresenter HorizontalAlignment="Stretch" />
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>

                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:NoteItem}">
                            <controls:NoteCard Note="{Binding}"
                                               DeleteRequested="NoteCard_DeleteRequested"
                                               TemplateChanged="NoteCard_TemplateChanged"
                                               ContentSaved="NoteCard_ContentSaved"
                                               PinToTopRequested="NoteCard_PinToTopRequested" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                </Grid>

            <!-- Resize is handled by WindowChrome.ResizeBorderThickness="4" -->
        </Grid>
    </Border>
</Window>