<Window x:Class="StickyNotes.MiniBallWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="便利贴悬浮球"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ResizeMode="NoResize"
        Width="52" Height="52"
        ShowInTaskbar="False"
        WindowStartupLocation="Manual"
        AllowDrop="True">

    <!-- Frosted glass ball -->
    <Border x:Name="BallBorder"
            Width="52" Height="52"
            CornerRadius="26"
            Cursor="Hand"
            AllowDrop="True"
            PreviewMouseLeftButtonDown="Ball_PreviewMouseDown"
            PreviewMouseMove="Ball_PreviewMouseMove"
            PreviewMouseLeftButtonUp="Ball_PreviewMouseUp"
            PreviewMouseRightButtonDown="Ball_PreviewRightDown"
            DragEnter="BallBorder_DragEnter"
            DragLeave="BallBorder_DragLeave"
            Drop="BallBorder_Drop">

        <!-- Frosted glass: radial gradient -->
        <Border.Background>
            <RadialGradientBrush GradientOrigin="0.3,0.3">
                <GradientStop Color="#F0FFFFFF" Offset="0" />
                <GradientStop Color="#D8F2F2F2" Offset="0.5" />
                <GradientStop Color="#C0E0E0E0" Offset="1" />
            </RadialGradientBrush>
        </Border.Background>

        <!-- Soft shadow -->
        <Border.Effect>
            <DropShadowEffect BlurRadius="18" Opacity="0.14"
                              ShadowDepth="3" Color="#000000" />
        </Border.Effect>

        <!-- Pushpin emoji -->
        <TextBlock Text="📌"
                   FontSize="24"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center" />
    </Border>
</Window>
